@model List<Project.Models.Service>

<div class="container mt-5">
    <h2 class="fw-bold mb-4">Ваша корзина</h2>

    @if (Model.Count == 0)
    {
        <div class="alert alert-light text-center p-5 border shadow-sm" style="border-radius: 20px;">
            <p class="lead text-muted mb-4">В корзине пока ничего нет</p>
            <a asp-action="Transactions" class="btn btn-primary rounded-pill px-4">Посмотреть услуги</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
               @foreach (var item in Model)
{
    <div class="cart-item mb-3 p-3">
        <div class="row g-0 align-items-center">
            <div class="col-md-2 col-3">
                <img src="@item.PhotoUrl" 
                     class="img-fluid" 
                     style="height: 70px; width: 100%; object-fit: cover; border-radius: 15px;" 
                     onerror="this.src='/Images/default.jpg'">
            </div>
            <div class="col-md-6 col-5 px-3">
                <h5 class="fw-bold m-0 text-dark">@item.Name</h5>
            </div>
            
            <div class="col-md-3 col-3 text-end">
                <span class="fw-bold text-primary">@item.Price.ToString("N0") ₽</span>
            </div>
            
            <div class="col-md-1 col-1 text-end">
                <a asp-action="RemoveFromCart" asp-route-id="@item.Id" class="delete-cart-btn">
                    Удалить
                </a>
            </div>
        </div>
    </div>
}
            </div>
            
            <div class="col-lg-4">
                <div class="card p-4 shadow-sm border-0 bg-white" style="border-radius: 25px;">
                    <h5 class="fw-bold mb-3">Итого</h5>
                    <div class="d-flex justify-content-between mb-4">
                        <span>Сумма заказа:</span>
                        <span class="fw-bold fs-5 text-primary">@Model.Sum(s => s.Price).ToString("N0") ₽</span>
                    </div>
                    <button class="btn btn-primary w-100 rounded-pill py-2 fw-bold">Оформить заказ</button>
                </div>
            </div>
        </div>
    }
</div>